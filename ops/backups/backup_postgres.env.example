# Copy this file to:
# ops/backups/backup_postgres.env
#
# Then customize values for your machine.
# The real backup_postgres.env should stay out of git.

INTERNAL_MOUNT=/media/chago/Storage
USB_MOUNT=/media/chago/backup

INTERNAL_DIR=/media/chago/Storage/postgres_backups
USB_DIR=/media/chago/backup/postgres_backups

CONTAINER_NAME=homelab-postgres
DB_NAME=homelab
DB_USER=homelab
DOCKER_BIN=/usr/bin/docker

INTERNAL_RETENTION_DAYS=7
USB_RETENTION_DAYS=14
